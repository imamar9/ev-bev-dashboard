# Copy this file to .env.local and fill in any keys you want to enable.
# The app works fully without any of these — all are optional.

# Enables a real Claude LLM in the chatbot (currently rule-based without this).
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Not used currently. Placeholder if switching Trip Planner to Google Maps APIs.
# GOOGLE_MAPS_API_KEY=
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
